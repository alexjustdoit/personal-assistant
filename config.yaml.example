server:
  host: 0.0.0.0
  port: 8000

llm:
  provider: ollama           # ollama | claude | openai | gemini | groq
  model: llama3.1:8b         # Ollama model — used when provider is ollama or as fallback
  ollama_url: http://localhost:11434
  quality_model: ollama      # used for quality_required=True tasks
  # briefing_provider: groq  # optional — overrides provider for briefing synthesis only

stt:
  enabled: true
  model: base            # tiny | base | small | medium | large-v3
  device: cuda           # cuda | cpu
  compute_type: float16  # float16 (GPU) | int8 (CPU)

tts:
  enabled: true
  voice: af_heart        # af_heart | af_bella | af_nicole | am_adam | am_michael
  speed: 1.0

briefing:
  enabled: true
  time: "07:00"          # 24hr format, morning briefing
  timezone: "America/New_York"  # IANA timezone name
  evening_enabled: false
  evening_time: "18:00"  # 24hr format, end-of-day briefing

weather:
  enabled: true
  api_key: ""            # OpenWeatherMap API key (free tier)
  city: "New York,US"   # City name or "City,CountryCode"
  units: imperial        # imperial (°F) | metric (°C)

calendar:
  enabled: false
  ical_urls: []          # List of private iCal URLs (Google/Outlook/Apple Calendar)
  # ical_url: ""         # Legacy single-URL format still supported

news:
  enabled: true
  topics: []             # e.g. ["technology", "politics", "local Seattle news"]
  api_key: ""            # Tavily API key (free tier at tavily.com) — enables web search in chat

notifications:
  ntfy_url: "https://ntfy.sh"
  ntfy_topic: ""         # Your unique topic name (e.g. "my-assistant-abc123")

todoist:
  api_token: ""          # Todoist API token — todoist.com → Settings → Integrations → API token

govee:
  api_key: ""            # Govee Developer API key — developer.govee.com → Apply for API key

email:
  # IMAP email fetching — supports multiple accounts (Gmail, Outlook, etc.)
  # Gmail:   myaccount.google.com/apppasswords → create an App Password (requires 2FA)
  # Outlook: use your regular password or an app password; host: outlook.office365.com
  fetch_hours: 24        # how far back to look (default 24 hours)
  max_per_account: 20   # max emails fetched per account (most recent first)
  accounts: []
  # accounts:
  #   - name: "Gmail"
  #     imap_host: imap.gmail.com
  #     imap_port: 993
  #     username: you@gmail.com
  #     password: "your-app-password"
  #   - name: "Outlook"
  #     imap_host: outlook.office365.com
  #     imap_port: 993
  #     username: you@outlook.com
  #     password: "your-password"

claude_memory:
  # Optional — path to your Claude Code memory folder (iCloud-synced markdown files).
  # Ingested as supplementary context. Leave blank to disable.
  # Windows: C:\Users\YourName\iCloudDrive\.claude\projects\<project-folder>\memory
  # Mac:     ~/Library/Mobile Documents/com~apple~CloudDocs/.claude/projects/<project-folder>/memory
  path: ""

# Folders to watch and index as searchable context.
# All paths are created automatically if they don't exist.
# Keep this list narrow — broad paths (e.g. Documents) will ingest everything recursively.
notes_folders:
  # - "C:\\Users\\YourName\\Notes\\activity"   # activity logs (add if activity_tracking is enabled)
  # - "C:\\Users\\YourName\\Notes\\personal"   # your own markdown/text notes

activity_tracking:
  enabled: false
  log_folder: ""               # where to write activity log files — should also be in notes_folders
  poll_interval_minutes: 30
  eod_summary_time: "22:00"    # time to synthesize a daily summary (24hr, local time)
  ignored_domains: []          # domains to exclude — also manageable via chat ("stop logging X")

# Cloud provider API keys — leave blank if not using
groq_api_key: ""         # Groq — console.groq.com (free tier, llama-3.3-70b)
gemini_api_key: ""       # Google AI Studio — aistudio.google.com (free tier, use AI Studio key not Cloud Console)
anthropic_api_key: ""    # Anthropic — console.anthropic.com
openai_api_key: ""       # OpenAI — platform.openai.com
openai_model: gpt-5.4-nano
