server:
  host: 0.0.0.0
  port: 8000

llm:
  provider: ollama       # ollama | claude | openai
  model: llama3.1:8b
  ollama_url: http://localhost:11434
  quality_model: claude  # used for quality_required=True tasks

stt:
  enabled: true
  model: base          # tiny | base | small | medium | large-v3
  device: cuda         # cuda | cpu
  compute_type: float16  # float16 (GPU) | int8 (CPU)

tts:
  enabled: true
  voice: af_heart      # af_heart | af_bella | af_nicole | am_adam | am_michael
  speed: 1.0

briefing:
  enabled: true
  time: "07:00"        # 24hr format
  timezone: "America/New_York"  # IANA timezone name

weather:
  enabled: true
  api_key: ""          # OpenWeatherMap API key (free tier)
  city: "New York,US"  # City name or "City,CountryCode"
  units: imperial      # imperial (°F) | metric (°C)

calendar:
  enabled: false
  ical_url: ""         # Private iCal URL from Google/Outlook/Apple Calendar

news:
  enabled: true
  api_key: ""          # Tavily API key (free tier)
  topics: []           # e.g. ["technology", "Formula 1", "local news"]

notifications:
  ntfy_url: "https://ntfy.sh"
  ntfy_topic: ""       # Your unique topic name (e.g. "my-assistant-abc123")

# Leave blank if not using
anthropic_api_key: ""
openai_api_key: ""
openai_model: gpt-4o-mini
